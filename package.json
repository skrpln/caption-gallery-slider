{
  "name": "caption-gallery-slider",
  "version": "0.1.0",
  "description": "Native-feeling gallery slider for local images and videos with editable Markdown captions.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "gallery",
    "slider",
    "carousel",
    "captions",
    "markdown",
    "media",
    "video"
  ],
  "author": "skrpln",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.30",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.28.1",
    "obsidian": "^1.5.12",
    "tslib": "^2.6.2",
    "typescript": "^5.4.2",
    "vitest": "^4.1.9"
  }
}
